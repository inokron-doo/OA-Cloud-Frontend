# Frontend environment (Vite). Copy to `.env` for local `npm run dev`.
#
# In the dockerized deploy you normally DON'T need these: the frontend container
# reverse-proxies /api and /farm-calendar on its own origin, and config defaults
# to relative paths. Override at runtime via the API_URL / FARM_CALENDAR_URL
# environment variables on the container instead (see docker-entrypoint.sh).

# Backend API base URL. For local dev against a running backend, e.g.:
VITE_API_URL=http://localhost:8080/api/v1

# Farm calendar SSO ENTRY (backend endpoint, NOT the calendar service directly).
# Opening it sends the login cookie; the backend then redirects to the real
# calendar's /post_auth. For local dev against a running backend, e.g.:
VITE_FARM_CALENDAR_URL=http://localhost:8080/api/v1/farm-calendar/
